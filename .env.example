# Super-HelloWorld 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ---- 应用配置 ----
LOG_LEVEL=INFO
RENDER_STYLE=plain
DEFAULT_ENCODING=utf-8

# ---- 云服务配置 ----
CLOUD_PROVIDER=aws
CLOUD_LOG_GROUP=/super-helloworld/production
CLOUD_REGION=us-east-1
# CLOUD_API_KEY=your-api-key
# CLOUD_API_SECRET=your-api-secret

# ---- 安全监控 ----
SECURITY_HIGH_FREQUENCY_THRESHOLD=100
SECURITY_RATE_WINDOW_SECONDS=1.0
SECURITY_MAX_PAYLOAD_SIZE=65536

# ---- 缓冲区 ----
BUFFER_MAX_SIZE=65536

# ---- 调度器 ----
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
